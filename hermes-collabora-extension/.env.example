# ==============================================================
#  Hermes Docker Compose — Environment Variables
#  Copy this file to .env and fill in your values
# ==============================================================

# ---- Host paths ----
# Path to the Hermes data directory on the host
HERMES_DATA_DIR=~/.hermes

# Path to your project/workspace directory on the host
WORKSPACE_DIR=~/Project

# ---- LLM Backend (set in ~/.hermes/.env, not here) ----
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://openagentic.id/api/v1
